# Application
APP_NAME=clowdbot-agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_VERSION=0.2.0
LOG_LEVEL=INFO

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# GitHub
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Operating Mode: monitor | assist | execute | incident
BOT_MODE=assist

# Database
SQLITE_PATH=./agent.db

# Shell Execution (set to true to enable allowlisted commands)
ALLOWED_EXECUTE=false

# Monitoring
HEALTH_CHECK_INTERVAL=60
