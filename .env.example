# Application
APP_NAME=clowdbot-agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_VERSION=0.2.0
LOG_LEVEL=INFO

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# GitHub
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_REPOSITORY=aalmanasir/clowdbot-agent

# Telegram phone control
TELEGRAM_BOT_TOKEN=
# Set after messaging the bot and running /whoami.
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_INTERVAL=3

# Google Cloud
GOOGLE_CLOUD_PROJECT=gen-lang-client-0910263735
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_MAPS_API_KEY=

# Operating Mode: monitor | assist | execute | incident
BOT_MODE=assist

# Database
SQLITE_PATH=./agent.db

# Shell Execution (set to true to enable allowlisted commands)
ALLOWED_EXECUTE=false

# Monitoring
HEALTH_CHECK_INTERVAL=60

# Local MCP stdio server
# Start with: python3 mcp_server.py

# Remote MCP endpoint for ChatGPT Developer Mode
# Public URL after deployment, for example: https://your-service.run.app
MCP_PUBLIC_BASE_URL=
# none | oauth
MCP_AUTH_MODE=none
# Required only when MCP_AUTH_MODE=oauth. Use a private random value.
MCP_OAUTH_PIN=
# Required only when MCP_AUTH_MODE=oauth. Use a long random secret.
MCP_OAUTH_TOKEN_SECRET=
